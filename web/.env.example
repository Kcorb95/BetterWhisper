# ── Authentication ────────────────────────────────────────────────
# Required. Shared secret between the macOS app and this backend.
# Generate one with: openssl rand -base64 32
AUTH_TOKEN=

# ── Transcription (Groq Whisper) ──────────────────────────────────
# Auto-added by the Groq Vercel integration.
# For local dev, get one at https://console.groq.com
GROQ_API_KEY=

# ── Post-processing (via Vercel AI Gateway) ───────────────────────
# On Vercel, auth is automatic via OIDC — no key needed.
# For local dev: Vercel Dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# Model for post-processing (format: "provider/model-name")
# Examples: anthropic/claude-sonnet-4.6, openai/gpt-5-mini, google/gemini-3-flash
PROCESSING_MODEL=anthropic/claude-haiku-4.5
